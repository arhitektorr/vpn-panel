# ============================================
# VPN ARHITEKTOR PANEL - Конфигурация
# ============================================

# ---------- Docker контейнер ----------
CONTAINER_NAME=amnezia-awg2
WG_INTERFACE=awg0

# ---------- Пути в контейнере ----------
SERVER_PUBLIC_KEY_PATH=/opt/amnezia/awg/wireguard_server_public_key.key

# ---------- Пути на хосте ----------
DB_PATH=/opt/vpn-panel/vpn.db
TEMPLATE_PATH=/opt/vpn-panel/awg_template.conf
CLIENTS_TABLE_PATH=/opt/amnezia/awg/clientsTable
PANEL_TMP_DIR=/opt/vpn-panel

# ---------- Сетевые настройки ----------
# ENDPOINT=ПУБЛИЧНЫЙ_IP_СЕРВЕРА:48758
# Пример: ENDPOINT=77.233.213.144:48758
ENDPOINT=SERVER_IP:PORT

# DNS серверы (можно оставить как есть)
DNS=172.29.172.254, 1.0.0.1

# ---------- Админ-панель (обязательно изменить!) ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password your

# ---------- API токен (обязательно изменить!) ----------
# Сгенерировать можно командой: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=сгенерируйте_новый_токен
